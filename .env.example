# ======================================================
# DEVIOZ WEB + AGENTE SOFIA - Variables de entorno
# Copiar a .env y completar con credenciales reales
# ======================================================

# --- Aplicacion ---
APP_ENV=production
APP_URL=http://localhost:8080
# Clave secreta para firmar tokens del panel admin (generar una aleatoria larga)
APP_KEY=cambiar-por-clave-aleatoria-de-64-caracteres-minimo

# --- Base de datos MySQL 8 ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=devioz_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- Groq API (Agente IA SofIA) ---
# Obtener en https://console.groq.com/keys
GROQ_API_KEY=TU_API_KEY_DE_GROQ_AQUI
# Modelo Llama 3 70B en Groq (llama3-70b-8192 fue retirado; usar la version vigente)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.4

# --- Culqi (Pagos en Soles: tarjetas, Yape) ---
# Llaves de prueba: pk_test_* / sk_test_* | Produccion: pk_live_* / sk_live_*
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# Secreto compartido para validar la firma HMAC del webhook (configurar en panel Culqi)
CULQI_WEBHOOK_SECRET=

# --- CORS ---
# Origenes permitidos separados por coma, o * para permitir todos
CORS_ALLOWED_ORIGINS=*

# --- Rate Limiting ---
RATE_LIMIT_PER_MIN=20

# --- Handoff humano ---
# Numero WhatsApp con codigo de pais, sin signos (ej: 51999999999)
WHATSAPP_NUMBER=51999999999

# --- Correo transaccional ---
# El remitente debe estar validado en tu proveedor (Resend, SendGrid, Mailgun, etc.)
# En desarrollo, PHP mail() usa el MTA del sistema; en producción configura SMTP en php.ini
MAIL_FROM=noreply@tudominio.pe
MAIL_FROM_NAME=Devioz
MAIL_REPLY_TO=contacto@tudominio.pe
